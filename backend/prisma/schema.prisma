// This is your Prisma schema file,
// more information about database design & Prisma: https://pris.ly/d/prisma-schema-docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ANGGOTA
  ADMIN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ANGGOTA)
  angkatan  String?
  nim       String?  // Nomor Induk Mahasiswa
  fakultas  String?  // Fakultas
  prodi     String?  // Program Studi/Jurusan
  birthDate DateTime? // Tanggal Lahir
  address   String?   // Alamat
  photo     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  payments      Payment[]
  withdrawals   Withdrawal[]
  savings       Saving?
  verifiedPayments   Payment[]  @relation("VerifiedPayments")
  verifiedWithdrawals Withdrawal[] @relation("VerifiedWithdrawals")
  refreshTokens RefreshToken[]
  loginHistory  LoginHistory[]
  notifications Notification[]

  @@map("users")
}

model Payment {
  id          String        @id @default(uuid())
  userId      String
  nominal     Decimal       @db.Decimal(15, 2)
  proofImage  String
  status      PaymentStatus @default(PENDING)
  description String?
  verifiedBy  String?
  verifiedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier User? @relation("VerifiedPayments", fields: [verifiedBy], references: [id])

  @@map("payments")
}

model Withdrawal {
  id          String           @id @default(uuid())
  userId      String
  nominal     Decimal          @db.Decimal(15, 2)
  reason      String
  status      WithdrawalStatus @default(PENDING)
  verifiedBy  String?
  verifiedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier User?  @relation("VerifiedWithdrawals", fields: [verifiedBy], references: [id])

  @@map("withdrawals")
}

model Saving {
  id        String   @id @default(uuid())
  userId    String   @unique
  total     Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("savings")
}

model RefreshToken {
  id                String   @id @default(uuid())
  token             String   @unique
  userId            String
  userAgent         String?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime @default(now())
  replacedByTokenId String?  @unique
  replacedByToken   RefreshToken? @relation("TokenRotation", fields: [replacedByTokenId], references: [id])
  nextToken         RefreshToken? @relation("TokenRotation")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model LoginHistory {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Connection info
  ipAddress      String
  userAgent      String
  
  // Parsed browser/device info
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?
  device         String?      // Desktop, Mobile, Tablet
  deviceBrand    String?
  deviceModel    String?
  
  // Location info
  country        String?
  city           String?
  region         String?
  
  // Status
  status         String       // SUCCESS, FAILED
  failureReason  String?
  
  createdAt      DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@index([ipAddress])
  @@map("login_history")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  // Null means broadcast to all admins
  type      String   // payment, withdrawal, system
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  isAdmin   Boolean  @default(false) // If true, visible to all admins
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
  @@map("notifications")
}
