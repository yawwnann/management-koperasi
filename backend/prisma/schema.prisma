// This is your Prisma schema file,
// more information about database design & Prisma: https://pris.ly/d/prisma-schema-docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ANGGOTA
  ADMIN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ANGGOTA)
  angkatan  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  payments      Payment[]
  withdrawals   Withdrawal[]
  savings       Saving?
  verifiedPayments   Payment[]  @relation("VerifiedPayments")
  verifiedWithdrawals Withdrawal[] @relation("VerifiedWithdrawals")

  @@map("users")
}

model Payment {
  id          String        @id @default(uuid())
  userId      String
  nominal     Decimal       @db.Decimal(15, 2)
  proofImage  String
  status      PaymentStatus @default(PENDING)
  description String?
  verifiedBy  String?
  verifiedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier User? @relation("VerifiedPayments", fields: [verifiedBy], references: [id])

  @@map("payments")
}

model Withdrawal {
  id          String           @id @default(uuid())
  userId      String
  nominal     Decimal          @db.Decimal(15, 2)
  reason      String
  status      WithdrawalStatus @default(PENDING)
  verifiedBy  String?
  verifiedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier User?  @relation("VerifiedWithdrawals", fields: [verifiedBy], references: [id])

  @@map("withdrawals")
}

model Saving {
  id        String   @id @default(uuid())
  userId    String   @unique
  total     Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("savings")
}
